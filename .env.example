RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=settings
RABBITMQ_ROUTING_KEY=user.settings.updated
RABBITMQ_QUEUE=meet.user_settings
RABBITMQ_PREFETCH=1

DATABASE_URL=postgres://meet_common_settings:change-me@localhost:5432/meet
MEET_USER_TABLE=meet_user

LANGUAGE_MAP_OVERRIDES={}

LOG_LEVEL=info
HEALTH_PORT=8080
SHUTDOWN_TIMEOUT_MS=10000
